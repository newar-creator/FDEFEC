    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #f0f2f5;
            font-family: 'Segoe UI', 'Roboto', 'Comic Neue', 'Helvetica Neue', sans-serif;
            padding: 30px 20px;
            color: #1e2a3a;
        }

        /* Contenedor principal estilo block de notas */
        .study-container {
            max-width: 1300px;
            margin: 0 auto;
        }

        h1 {
            text-align: center;
            font-size: 2.2rem;
            background: linear-gradient(135deg, #1e3c72, #2b4c7c);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            margin-bottom: 10px;
            letter-spacing: -0.5px;
        }

        .sub {
            text-align: center;
            color: #4a627a;
            margin-bottom: 40px;
            font-weight: 500;
            border-bottom: 2px dashed #cbd5e1;
            display: inline-block;
            width: auto;
            margin-left: auto;
            margin-right: auto;
            padding-bottom: 8px;
        }

        /* Grid de fichas estilo tarjetas */
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 25px;
        }

        /* cada ficha */
        .study-card {
            background: white;
            border-radius: 28px;
            box-shadow: 0 12px 22px -10px rgba(0, 0, 0, 0.12);
            transition: transform 0.2s ease, box-shadow 0.2s;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            border: 1px solid #e4e9f0;
        }

        .study-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 28px -12px rgba(0, 0, 0, 0.2);
        }

        /* cabecera de la ficha */
        .card-header {
            background: #2c3e66;
            color: white;
            padding: 18px 20px;
            font-weight: bold;
            font-size: 1.35rem;
            letter-spacing: -0.2px;
            border-bottom: 4px solid #f9b43a;
        }

        .card-header span {
            background: #f9b43a;
            color: #1e2a3a;
            font-size: 0.8rem;
            border-radius: 40px;
            padding: 4px 10px;
            margin-left: 12px;
            vertical-align: middle;
            font-weight: 600;
        }

        /* contenido de la respuesta */
        .card-content {
            padding: 20px 22px;
            background: #fefefe;
            flex-grow: 1;
            font-size: 1rem;
            line-height: 1.5;
            color: #1e2f3e;
        }

        .card-content p {
            margin-bottom: 12px;
        }

        .card-content ul, .card-content ol {
            margin-left: 22px;
            margin-bottom: 12px;
        }

        .card-content li {
            margin: 6px 0;
        }

        .example-box {
            background: #f8f9fc;
            border-left: 5px solid #f9b43a;
            padding: 12px 16px;
            margin: 12px 0;
            border-radius: 16px;
            font-size: 0.95rem;
        }

        .badge {
            background: #eef2ff;
            color: #2c3e66;
            border-radius: 30px;
            padding: 4px 12px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
            margin-bottom: 8px;
        }

        hr {
            margin: 15px 0;
            border: 0;
            height: 1px;
            background: #ddd;
        }

        .footer-note {
            text-align: center;
            margin-top: 45px;
            font-size: 0.85rem;
            color: #4b6b8f;
            background: #e9edf2;
            padding: 14px;
            border-radius: 60px;
            width: fit-content;
            margin-left: auto;
            margin-right: auto;
        }

